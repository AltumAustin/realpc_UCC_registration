# Bland.ai API Key for automated phone outreach
# Obtain from https://app.bland.ai
BLAND_API_KEY=your_bland_api_key_here

# === UCC Filing Ingestion Pipeline ===

# SQLite database path (default: data/ucc_filings.db)
# UCC_DB_PATH=data/ucc_filings.db

# Directory for bulk data downloads (default: data/bulk_downloads)
# UCC_DOWNLOAD_DIR=data/bulk_downloads

# Socrata app token (optional, raises rate limits for CT/CO open data APIs)
# Register at https://data.ct.gov/profile/edit/developer_settings
# SOCRATA_APP_TOKEN=your_socrata_app_token

# Commercial provider for Tier 3 states (baselayer | fcs | lexisnexis)
UCC_COMMERCIAL_PROVIDER=baselayer
UCC_COMMERCIAL_API_URL=https://api.example.com
UCC_COMMERCIAL_API_KEY=your_commercial_api_key

# State bulk data credentials (Tier 2) — format: username:password
# TX_BULK_CREDENTIALS=user:pass
# KY_BULK_CREDENTIALS=user:pass
# WV_BULK_CREDENTIALS=user:pass
# ID_BULK_CREDENTIALS=user:pass
# ND_BULK_CREDENTIALS=user:pass
# MN_BULK_CREDENTIALS=user:pass
# AR_INA_CREDENTIALS=user:pass
# IN_INBIZ_CREDENTIALS=user:pass
# NY_SUBSCRIPTION_CREDENTIALS=user:pass
# NC_SUBSCRIPTION_CREDENTIALS=user:pass
# SC_BULK_CREDENTIALS=user:pass
# SD_BULK_CREDENTIALS=user:pass
